{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "@relay/claude-code-integration#build": {
      "dependsOn": ["^build", "@relay/integration-core#build"]
    },
    "@relay/codex-integration#build": {
      "dependsOn": ["^build", "@relay/integration-core#build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@relay/desktop#dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    }
  }
}
